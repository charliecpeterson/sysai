#!/usr/bin/env bash
# ai-pane — open or attach the sysai tmux pane
#
# Usage: ai-pane
#   Opens a vertical split with the sysai server in the right pane.
#   If the pane is already running in this tmux session, switches to it.
#   If not in tmux, just runs the server inline.

set -euo pipefail

SYSAI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER="$SYSAI_DIR/server.js"

# Not in tmux — just run inline
if [ -z "${TMUX:-}" ]; then
  echo "sysai: not in a tmux session. Running inline (no pane routing)."
  exec node "$SERVER"
fi

# Check if the pane is already registered in this session's environment
EXISTING_PANE=$(tmux show-environment SYSAI_PANE 2>/dev/null | sed 's/SYSAI_PANE=//' || true)

if [ -n "$EXISTING_PANE" ]; then
  # Verify the pane actually still exists
  if tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -qF "$EXISTING_PANE"; then
    echo "sysai: switching to existing AI pane ($EXISTING_PANE)"
    tmux select-pane -t "$EXISTING_PANE"
    exit 0
  fi
fi

# Open a new split pane on the right (45 columns wide)
# Pane runs the sysai server; -P prints the new pane ID
NEW_PANE=$(tmux split-window -h -l 45 -P -F '#{pane_id}' "node '$SERVER'")

# Store the pane ID in the tmux session environment
tmux set-environment SYSAI_PANE "$NEW_PANE"

echo "sysai: AI pane opened ($NEW_PANE). Use '? <question>' to send queries to it."
